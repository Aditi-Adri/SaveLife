# Copy this file to .env and fill in real values (local development)
PORT=4000
NODE_ENV=development

# PostgreSQL connection
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/savelife

# Set to "true" when your database requires SSL (e.g. Render, Neon).
# Leave false for a local PostgreSQL install.
PGSSL=false

# JSON Web Token settings — use a long random string for JWT_SECRET in production
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# Allowed origin for the frontend during local dev (Vite dev server)
CLIENT_ORIGIN=http://localhost:5173
